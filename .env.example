# Required: Telegram bot token used for Mini App auth.
# Replace this placeholder with your real bot token.
TELEGRAM_BOT_TOKEN=123456...e_me

# Required for Telegram-facing use: HTTPS URL that Telegram opens for the Mini App.
# Any domain or subdomain you control is fine; the name itself does not matter much.
# What matters is valid HTTPS and that this exactly matches the URL your bot opens.
MINI_APP_URL=https://your-domain.com/app

# Optional: local Flask port when running the app directly.
PORT=8080

# Hermes backend choice: pick one path that matches your setup.

# Option A: simplest remote setup.
HERMES_API_URL=

# Option B: best streaming UX if you already have a streaming endpoint.
HERMES_STREAM_URL=

# Option C: local Hermes on the same machine.
# On Windows, run the Mini App from WSL2; Hermes Agent does not support a native Windows runtime path.
# Leave these unset if you are using HERMES_API_URL or HERMES_STREAM_URL.
HERMES_CLI_COMMAND=hermes
HERMES_MODEL=
HERMES_TIMEOUT_SECONDS=120
HERMES_STREAM_CHUNK_SIZE=28

# Optional local Hermes Agent path overrides.
# These are only needed if your local Hermes install does not live in the default location.
# Avoid platform-specific path examples unless you know the target machine.
# MINI_APP_AGENT_HOME=
# MINI_APP_AGENT_HERMES_HOME=
# MINI_APP_AGENT_WORKDIR=
# MINI_APP_AGENT_VENV=
# MINI_APP_AGENT_PYTHON=

# Optional file preview policy.
# Keep roots narrow and project-focused.
# On POSIX systems entries are colon-separated. On Windows use normal Windows paths if you override these.
# MINI_APP_FILE_PREVIEW_ALLOWED_ROOTS=/path/to/project:/path/to/docs
# Optional denylist overrides. Responses expose only coarse rule classes (`basename_glob` / `path_glob`).
# MINI_APP_FILE_PREVIEW_DENY_BASENAME_GLOBS=.env:.env.*:auth.json:*.pem:*.key:id_ed25519
# MINI_APP_FILE_PREVIEW_DENY_PATH_GLOBS=*/.env:*/.env.*:*/checkpoints/*:*/.ssh/*

# Hardening / limits
FLASK_DEBUG=0
MAX_MESSAGE_LEN=4000
MAX_TITLE_LEN=120
MAX_CONTENT_LENGTH=1048576

# Permanent-domain security (recommended in production)
# MINI_APP_ALLOWED_ORIGINS=https://miniapp.example.com
# MINI_APP_ENFORCE_ORIGIN_CHECK=1
# MINI_APP_FORCE_SECURE_COOKIES=1
# MINI_APP_TRUST_PROXY_HEADERS=1
# MINI_APP_ENABLE_HSTS=1
# MINIAPP_DEV_BYPASS=0
# MINIAPP_DEV_SECRET=replac...cret
# MINI_APP_RATE_LIMIT_WINDOW_SECONDS=60
# MINI_APP_RATE_LIMIT_API_REQUESTS=180
# MINI_APP_RATE_LIMIT_STREAM_REQUESTS=24

# See .env.permanent-domain.example for a more complete production profile.
