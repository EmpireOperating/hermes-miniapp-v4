# Production-oriented profile for a permanent HTTPS domain.
# Copy to .env and replace placeholders.

TELEGRAM_BOT_TOKEN=123456:replace_me
MINI_APP_URL=https://miniapp.example.com/app
PORT=8787

# Hermes routing (recommended: follow Hermes auth/config runtime)
HERMES_MODEL=auto
HERMES_PROVIDER=auto
HERMES_BASE_URL=auto
HERMES_TIMEOUT_SECONDS=120
HERMES_STREAM_CHUNK_SIZE=28

# Optional fixed endpoints (leave blank when using auto routing above)
HERMES_API_URL=
HERMES_STREAM_URL=
HERMES_CLI_COMMAND=hermes

# Request limits
FLASK_DEBUG=0
MAX_MESSAGE_LEN=4000
MAX_TITLE_LEN=120
MAX_CONTENT_LENGTH=1048576

# Optional file preview policy.
# Keep roots narrow and project-focused; entries are colon-separated on Linux.
# MINI_APP_FILE_PREVIEW_ALLOWED_ROOTS=/path/to/workspace:/path/to/hermes-agent/docs
# Optional denylist overrides. Responses expose only coarse rule classes (`basename_glob` / `path_glob`).
# MINI_APP_FILE_PREVIEW_DENY_BASENAME_GLOBS=.env:.env.*:auth.json:*.pem:*.key:id_ed25519
# MINI_APP_FILE_PREVIEW_DENY_PATH_GLOBS=*/.env:*/.env.*:*/checkpoints/*:*/.ssh/*

# Permanent-domain hardening
MINI_APP_ALLOWED_ORIGINS=https://miniapp.example.com
MINI_APP_ENFORCE_ORIGIN_CHECK=1
MINI_APP_FORCE_SECURE_COOKIES=1
MINI_APP_TRUST_PROXY_HEADERS=1
MINI_APP_ENABLE_HSTS=1
MINIAPP_DEV_BYPASS=0
# Keep the secret present but dormant so you can temporarily enable QA/debugging.
MINIAPP_DEV_SECRET=replace-with-long-random-secret

# Rate limits (tune for your traffic)
MINI_APP_RATE_LIMIT_WINDOW_SECONDS=60
MINI_APP_RATE_LIMIT_API_REQUESTS=180
MINI_APP_RATE_LIMIT_STREAM_REQUESTS=24

# Queue/runtime
MINI_APP_JOB_MAX_ATTEMPTS=4
MINI_APP_JOB_RETRY_BASE_SECONDS=2
MINI_APP_JOB_WORKER_CONCURRENCY=6
MINI_APP_JOB_STALL_TIMEOUT_SECONDS=240
MINI_APP_JOB_EVENT_HISTORY_MAX_JOBS=256
MINI_APP_JOB_EVENT_HISTORY_TTL_SECONDS=1800
